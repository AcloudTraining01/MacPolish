# MacPolish — local development environment.
#
# Copy this file to `.env` and fill in your OpenRouter key.
# The build script Tools/generate-dev-key.sh reads this file and
# embeds the key into Debug builds only. Release builds always
# fall back to BYOK (user-entered key in Settings).
#
# NEVER commit `.env` to git. NEVER paste a real key into this template.

OPENROUTER_API_KEY=
